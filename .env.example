# Default: mock mode on, no API calls.
SUPGREAT_MOCK=1

# Für echten Claude-Vision-Betrieb: SUPGREAT_MOCK=0 und Key eintragen.
ANTHROPIC_API_KEY=sk-ant-...

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Shopify Cart Permalink Integration ─────────────────────────────
# Shop-Domain (ohne Protokoll), z. B. "supgreat.myshopify.com".
NEXT_PUBLIC_SHOPIFY_DOMAIN=

# JSON-Mapping von SKU auf Shopify Variant-ID (eine Zeile, kein ENTER).
# Für die Core Box gibt es pro Plan eine eigene Variante (Suffix -ONCE / -ABO).
# Module sind plan-unabhängig — nur die SKU ohne Suffix. Beispiel:
# {"COREBOX-30D-ONCE":"45678901","COREBOX-30D-ABO":"45678902","MOD-MAG-30D":"45678903"}
SHOPIFY_VARIANT_MAP=
